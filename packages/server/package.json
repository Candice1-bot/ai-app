      "body-parser": "^2.2.0",
      "cors": "^2.8.5",
      "dayjs": "^1.11.18",
      "dotenv": "^17.2.3",
      "express": "^5.1.0",
      "helmet": "^8.1.0",
      "jsonwebtoken": "^9.0.2",
      "morgan": "^1.10.1",
      "ollama": "^0.6.0",
      "openai": "^6.1.0",
      "prisma": "^6.17.0",
      "zod": "^4.1.11"
   },
   "devDependencies": {
